    {
      "parameters": {
        "jsCode": "// Mapping model labels to diseases\nconst labelColumns = ['Cardiomegaly', 'Edema', 'Consolidation', 'Pneumonia', 'No Finding'];\n\n// Hugging Face response (ensure array of predictions)\nlet results = items[0].json; // e.g., [{label: \"LABEL_2\", score: 0.2925}]\nif (!Array.isArray(results)) {\n  results = [results];\n}\n\n// Convert labels and calculate severity\nconst severityResults = results.map(disease => {\n  const index = parseInt(disease.label.split('_')[1]);\n  const humanLabel = labelColumns[index] || disease.label;\n  const severityScore = (disease.score * 100).toFixed(1); // 0-100 scale\n\n  return {\n    label: humanLabel,\n    probability: disease.score,\n    severity_score: severityScore\n  };\n});\n\n// Prepare human-readable message for Telegram\nconst messageText = severityResults.map(d => `${d.label}: ${d.severity_score}%`).join('\\n');\n\nreturn [\n  {\n    json: {\n      severity: severityResults,\n      telegramMessage: messageText\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        -320
      ],
      "id": "e69f83a7-675c-480c-9aec-0f02cfadf400",
      "name": "Code in JavaScript"
    },
